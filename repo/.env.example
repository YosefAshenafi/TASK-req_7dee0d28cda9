# FulfillOps — environment variable reference
# Copy to .env and fill in values before running locally without Docker.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://fulfillops:fulfillops_dev@localhost:5432/fulfillops?sslmode=disable

# ── Encryption ───────────────────────────────────────────────────────────────
# Path to a file containing exactly 32 bytes (base64-encoded AES-256 key).
# Permissions must be 0600. Generate with: make generate-key
FULFILLOPS_ENCRYPTION_KEY_PATH=./encryption.key

# ── Storage directories ───────────────────────────────────────────────────────
FULFILLOPS_EXPORT_DIR=./exports
FULFILLOPS_BACKUP_DIR=./backups
FULFILLOPS_ASSETS_DIR=./assets
FULFILLOPS_MIGRATIONS_PATH=./migrations

# ── HTTP server ───────────────────────────────────────────────────────────────
FULFILLOPS_PORT=8080

# ── Session security ──────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
FULFILLOPS_SESSION_SECRET=replace-with-a-random-32-char-or-longer-string

# Set to false for local HTTP development (no TLS). Always true in production.
FULFILLOPS_SECURE_COOKIES=false

# ── Bootstrap admin (first-run only) ─────────────────────────────────────────
# Provide both to create the first administrator account on startup.
# No hard-coded credentials are seeded; these are the only way to create the
# initial admin. The account is flagged must_rotate_password=true, so the
# password must be changed on first login.
FULFILLOPS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
FULFILLOPS_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# ── Scheduler ────────────────────────────────────────────────────────────────
# IANA timezone name for daily job scheduling (e.g. America/New_York).
# Leave empty to use UTC.
FULFILLOPS_SCHEDULER_TZ=

# ── Framework ────────────────────────────────────────────────────────────────
GIN_MODE=debug
