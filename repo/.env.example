# Database
DATABASE_URL=postgres://fulfillops:fulfillops_dev@db:5432/fulfillops?sslmode=disable
DB_PASSWORD=fulfillops_dev

# Encryption
# Path inside the container - the key file is mounted via docker-compose volume
FULFILLOPS_ENCRYPTION_KEY_PATH=/app/encryption.key
# Host path to the 32-byte key file (generated with: make generate-key)
ENCRYPTION_KEY_FILE=./docker/encryption.key.dev

# Storage directories (inside container)
FULFILLOPS_EXPORT_DIR=/app/exports
FULFILLOPS_BACKUP_DIR=/app/backups

# Server
FULFILLOPS_PORT=8080

# Session (must be at least 32 characters in production - use a random value)
FULFILLOPS_SESSION_SECRET=dev-session-secret-change-in-prod!!

# Gin mode: debug | release | test
GIN_MODE=debug
